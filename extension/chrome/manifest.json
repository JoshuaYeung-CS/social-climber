{
  "manifest_version": 3,
  "name": "Social Climber",
  "version": "1.0.7",
  "description": "Auto-fills the Instagram data export wizard and overlays your local Social Climber history on profile pages.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "alarms",
    "debugger"
  ],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://accountscenter.instagram.com/*",
    "https://accounts.google.com/*",
    "https://*.cdninstagram.com/*",
    "https://*.fbcdn.net/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Social Climber",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content/ig-profile.js"],
      "css": ["content/ig-profile.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://accountscenter.instagram.com/*",
        "https://www.instagram.com/accounts/center/*"
      ],
      "js": ["content/meta-export.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://accounts.google.com/*"],
      "js": ["content/google-oauth.js"],
      "run_at": "document_idle"
    }
  ]
}
